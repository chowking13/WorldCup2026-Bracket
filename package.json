{
  "name": "wc2026-bracket",
  "productName": "World Cup 2026 Bracket",
  "version": "1.0.0",
  "description": "Interactive FIFA World Cup 2026 bracket with score entry, auto-standings, and a Monte Carlo prediction engine.",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.bracket.wc2026",
    "productName": "World Cup 2026 Bracket",
    "files": [
      "main.js",
      "index.html",
      "build/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.sports"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Game"
    }
  }
}
